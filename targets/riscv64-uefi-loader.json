{
  "arch": "riscv64",
  "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n32:64-S128",
  "llvm-target": "riscv64",

  "os": "uefi",
  "env": "",
  "vendor": "rustos",

  "linker": "rust-lld",
  "linker-flavor": "lld-link",
  "lld-flavor": "link",

  "executables": true,
  "disable-redzone": true,

  "panic-strategy": "abort",

  "relocation-model": "static",
  "code-model": "medium",

  "features": "+m,+a,+f,+d,+c",

  "max-atomic-width": 64,

  "frame-pointer": "always",

  "pre-link-args": {
    "lld-link": [
      "/subsystem:efi_application",
      "/entry:efi_main"
    ]
  }
}
