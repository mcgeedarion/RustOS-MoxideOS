From: RustOS <kernel@rustos>
Subject: [PATCH 1/2] arch/x86_64,riscv64: rustos syscall + errno-in-TLS shim

Replaces the Linux-specific ERRNO_LOCATION and __syscall_ret with
RustOS equivalents:

  * errno lives at fs:0x00 (x86_64 TCB offset 0) / tp+0x00 (riscv64),
    matching the TLS layout installed by the kernel at execve.
  * __syscall_ret negates a negative return value and stores it in the
    per-thread errno slot, then returns -1 — identical to musl's Linux
    path but with the correct TLS offset.
  * __syscall (the raw wrapper) is unchanged — it already uses the
    'syscall' instruction on x86_64 and 'ecall' on riscv64.

--- a/arch/x86_64/syscall_arch.h
+++ b/arch/x86_64/syscall_arch.h
@@ -1,6 +1,8 @@
+/* RustOS sysdep — errno at fs:0x00 (TCB offset 0) */
+#define SYSCALL_NO_ERRNO_IN_TLS 0
+
 static inline long __syscall_ret(unsigned long r)
 {
-	if (r > -4096UL) { errno = -r; return -1; }
+	if (r > -4096UL) {
+		__asm__ volatile ("mov %0, %%fs:0x0" :: "r"((long)-r) : "memory");
+		return -1;
+	}
 	return r;
 }

--- a/arch/riscv64/syscall_arch.h
+++ b/arch/riscv64/syscall_arch.h
@@ -1,6 +1,11 @@
+/* RustOS sysdep — errno at tp+0x00 */
+#define SYSCALL_NO_ERRNO_IN_TLS 0
+
 static inline long __syscall_ret(unsigned long r)
 {
-	if (r > -4096UL) { errno = -r; return -1; }
+	if (r > -4096UL) {
+		register long _e asm("t0") = (long)-r;
+		__asm__ volatile ("sw %0, 0(tp)" :: "r"(_e) : "memory");
+		return -1;
+	}
 	return r;
 }

--- a/src/env/__init_tls.c
+++ b/src/env/__init_tls.c
@@ -30,7 +30,9 @@
 	 * RustOS: the kernel already mapped and zero-filled the TLS block
 	 * at the address specified in the AuxVector (AT_BASE_PLATFORM = TLS
 	 * base for static executables).  We just need to set fs/tp.
+	 * The kernel also wrote the stack canary at TLS+0x28 (x86_64) /
+	 * TLS+0x28 (riscv64) — see security/canary.rs.
 	 */
+	/* rustos: TLS base already prepared by execve — skip PT_TLS copy */
 	if (!libc.tls_size) return 0;
 	__set_thread_area(tls_base);
 	return 0;
