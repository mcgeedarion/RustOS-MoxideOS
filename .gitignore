# Cargo build output
/target/

# Cargo.lock is committed for binaries / kernels by convention.
# Leave it tracked once it's committed; don't add it here.

# rustup-pinned local overrides
/rust-toolchain

# Legacy QEMU / EDK2 transient artifacts. Current scripts place VARS files under /target/.
/edk2-aarch64-vars.fd
/edk2-riscv-vars.fd

# Legacy UEFI ESP staging directory. Current scripts use /target/esp/<arch>/.
/esp/

# Disk images produced by cargo xtask image
/boot-aarch64.img
/boot-riscv64.img
/boot.img
/boot-x86_64.img

# Editor / OS clutter
*.swp
.DS_Store
